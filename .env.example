# Azure Billing Configuration Template
# Copy this file to .env and update with your actual values

# For Invoice Sections and Subscriptions Scripts
TENANT_ID=your-tenant-id-guid
BILLING_ACCOUNT_ID=your-billing-account-id
BILLING_PROFILE_ID=your-billing-profile-id

# GitHub Configuration
# For GitHub Cost Centers Script
GITHUB_ORG=your-github-organization
GITHUB_ENTERPRISE=your-github-enterprise-slug
GITHUB_PAT=ghp_your_personal_access_token_here
# Optional for GitHub Enterprise Server (example: https://api.SUBDOMAIN.ghe.com)
# GITHUB_API_BASE_URL=https://api.github.com
# Optional override if GitHub API path changes in your environment
# GITHUB_ENTERPRISE_COST_CENTER_ENDPOINT=/enterprises/your-github-enterprise-slug/settings/billing/cost-centers

# Execution Control
DRY_RUN=true

# CSV File Configuration
CSV_FILE_PATH=mapping.csv
